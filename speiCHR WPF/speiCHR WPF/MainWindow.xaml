<Window x:Class="speiCHR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:speiCHR"
        mc:Ignorable="d"
        Title="speiCHR" Height="450" Width="800">
    <Grid>
        <Button x:Name="OpenFileButton" Content="Open" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Click="OpenFileButton_Click"/>
        <StatusBar x:Name="FileStatus" HorizontalAlignment="Left" VerticalAlignment="Bottom" Height="25" Width="800" Margin="0,0,0,0">
            <TextBlock Text="Editing: " TextWrapping="Wrap"/>
            <TextBlock x:Name="TB_FileName" Text="&lt;no file&gt;" TextWrapping="Wrap"/>
        </StatusBar>

    </Grid>
</Window>
